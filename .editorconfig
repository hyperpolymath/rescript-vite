# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# JavaScript/TypeScript/JSX/TSX
[*.{js,jsx,ts,tsx,mjs}]
indent_style = space
indent_size = 2

# ReScript
[*.{res,resi}]
indent_style = space
indent_size = 2

# JSON
[*.json]
indent_style = space
indent_size = 2

# Markdown
[*.{md,adoc}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Makefile/Justfile
[{Makefile,Justfile,justfile}]
indent_style = tab

# Shell
[*.{sh,bash}]
indent_style = space
indent_size = 2

# HTML/CSS
[*.{html,css,scss}]
indent_style = space
indent_size = 2

# gitkeep files
[.gitkeep]
insert_final_newline = false
